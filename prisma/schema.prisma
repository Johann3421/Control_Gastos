generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH ====================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  image         String?
  emailVerified DateTime?
  currency      String    @default("PEN")
  locale        String    @default("es-PE")
  theme         String    @default("light")
  monthStart    Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  wallets      Wallet[]
  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]
  goals        SavingGoal[]
  recurringTx  RecurringTransaction[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==================== BILLETERAS ====================
model Wallet {
  id             String     @id @default(cuid())
  name           String
  type           WalletType
  balance        Decimal    @db.Decimal(14, 2) @default(0)
  currency       String     @default("PEN")
  color          String     @default("#6366f1")
  icon           String     @default("wallet")
  isDefault      Boolean    @default(false)
  includeInTotal Boolean    @default(true)
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  transfersFrom  Transfer[] @relation("TransferFrom")
  transfersTo    Transfer[] @relation("TransferTo")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([userId])
  @@map("wallets")
}

// ==================== CATEGORÍAS ====================
model Category {
  id           String          @id @default(cuid())
  name         String
  type         TransactionType
  icon         String          @default("tag")
  color        String          @default("#6366f1")
  parentId     String?
  parent       Category?       @relation("SubCategories", fields: [parentId], references: [id])
  children     Category[]      @relation("SubCategories")
  isDefault    Boolean         @default(false)
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  createdAt    DateTime        @default(now())

  @@unique([userId, name, type])
  @@index([userId, type])
  @@map("categories")
}

// ==================== TRANSACCIONES ====================
model Transaction {
  id          String          @id @default(cuid())
  amount      Decimal         @db.Decimal(14, 2)
  type        TransactionType
  description String
  notes       String?         @db.Text
  date        DateTime        @db.Date
  time        String?
  isRecurring Boolean         @default(false)
  tags        String[]
  attachments String[]
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  walletId    String
  wallet      Wallet          @relation(fields: [walletId], references: [id])
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurringId String?
  recurring   RecurringTransaction? @relation(fields: [recurringId], references: [id])
  goalId      String?
  goal        SavingGoal?     @relation(fields: [goalId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId, date])
  @@index([userId, type])
  @@index([categoryId])
  @@index([walletId])
  @@map("transactions")
}

// ==================== TRANSFERENCIAS ====================
model Transfer {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(14, 2)
  amountTo    Decimal  @db.Decimal(14, 2)
  description String?
  date        DateTime @db.Date
  fromId      String
  from        Wallet   @relation("TransferFrom", fields: [fromId], references: [id])
  toId        String
  to          Wallet   @relation("TransferTo", fields: [toId], references: [id])
  userId      String
  createdAt   DateTime @default(now())

  @@map("transfers")
}

// ==================== PRESUPUESTOS ====================
model Budget {
  id         String       @id @default(cuid())
  name       String
  amount     Decimal      @db.Decimal(14, 2)
  period     BudgetPeriod
  startDate  DateTime     @db.Date
  endDate    DateTime?    @db.Date
  rollover   Boolean      @default(false)
  alertAt    Int          @default(80)
  categoryId String?
  category   Category?    @relation(fields: [categoryId], references: [id])
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([userId])
  @@map("budgets")
}

// ==================== METAS DE AHORRO ====================
model SavingGoal {
  id            String     @id @default(cuid())
  name          String
  targetAmount  Decimal    @db.Decimal(14, 2)
  currentAmount Decimal    @db.Decimal(14, 2) @default(0)
  currency      String     @default("PEN")
  deadline      DateTime?  @db.Date
  icon          String     @default("target")
  color         String     @default("#6366f1")
  status        GoalStatus @default(IN_PROGRESS)
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
  @@map("saving_goals")
}

// ==================== TRANSACCIONES RECURRENTES ====================
model RecurringTransaction {
  id          String              @id @default(cuid())
  description String
  amount      Decimal             @db.Decimal(14, 2)
  type        TransactionType
  frequency   RecurrenceFrequency
  startDate   DateTime            @db.Date
  endDate     DateTime?           @db.Date
  nextDate    DateTime            @db.Date
  dayOfMonth  Int?
  active      Boolean             @default(true)
  categoryId  String
  walletId    String
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([userId, nextDate])
  @@map("recurring_transactions")
}

// ==================== ENUMS ====================
enum WalletType {
  CASH
  BANK
  DIGITAL
  CREDIT
  INVESTMENT
  SAVINGS
}

enum TransactionType {
  INCOME
  EXPENSE
  SAVING
  INVESTMENT
  TRANSFER
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum GoalStatus {
  IN_PROGRESS
  COMPLETED
  PAUSED
  CANCELLED
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}
